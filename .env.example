# Neon PostgreSQL connection string
# Get this from your Neon project dashboard: https://neon.tech
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here

# Base URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Flagging thresholds (optional — these are the defaults)
FLAG_FOCUS_LOSS_THRESHOLD=3
FLAG_MIN_EDIT_EVENTS=10
FLAG_MIN_RESPONSE_LENGTH=200

# Autosave history retention in days (default: 30)
AUTOSAVE_RETENTION_DAYS=30
