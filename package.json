{
  "name": "recoding-exercise-platform",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "migrate": "psql $DATABASE_URL -f migrations/run_all.sql",
    "db:reset": "psql $DATABASE_URL -f migrations/reset_keep_users.sql",
    "test:watch": "vitest",
    "migrate:fresh": "tsx scripts/migrate.ts fresh && tsx scripts/seed.ts && tsx scripts/create-users.ts && tsx scripts/import-questions.ts",
    "seed": "tsx scripts/seed.ts",
    "create-users": "tsx scripts/create-users.ts",
    "import-questions": "tsx scripts/import-questions.ts",
    "cleanup": "tsx scripts/cleanup-autosave.ts",
    "reset-password": "tsx scripts/reset-password.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@neondatabase/serverless": "^0.9.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "csv-stringify": "^6.7.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "fast-check": "^3.19.0",
    "monaco-editor": "^0.55.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^1.6.0"
  }
}
